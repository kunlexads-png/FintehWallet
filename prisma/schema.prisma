datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum CardStatus {
  ACTIVE
  FROZEN
  CANCELLED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_SENT
  TRANSFER_RECEIVED
  BILL_PAYMENT
  INVESTMENT_FUND
  CASHBACK
}

enum InvestmentType {
  SAVINGS_GOAL
  FIXED_DEPOSIT
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String
  name               String
  role               Role           @default(USER)
  isVerified         Boolean        @default(false)
  kycStatus          KYCStatus      @default(NOT_SUBMITTED)
  twoFactorEnabled   Boolean        @default(false)
  twoFactorSecret    String?
  referralCode       String         @unique
  referredBy         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  wallets            Wallet[]
  virtualCards       VirtualCard[]
  investments        Investment[]
  kycRequest         KycRequest?
  notifications      Notification[]
}

model Wallet {
  id             String        @id @default(uuid())
  userId         String
  currency       String        @default("USD")
  balance        Float         @default(0.0)
  ledgerBalance  Float         @default(0.0)
  dailyLimit     Float         @default(5000.0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  virtualCards   VirtualCard[]
}

model Transaction {
  id             String            @id @default(uuid())
  walletId       String
  type           TransactionType
  category       String            // e.g., Food, Transport, Bills, Shopping, Entertainment, Salary, Investments
  amount         Float
  fee            Float             @default(0.0)
  status         TransactionStatus @default(SUCCESS)
  reference      String            @unique
  description    String?
  createdAt      DateTime          @default(now())

  wallet         Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Transfer {
  id                String            @id @default(uuid())
  sourceWalletId    String
  targetWalletId    String
  amount            Float
  fee               Float             @default(0.0)
  description       String?
  isScheduled       Boolean           @default(false)
  scheduledDate     DateTime?
  status            TransactionStatus @default(SUCCESS)
  createdAt         DateTime          @default(now())
}

model VirtualCard {
  id             String     @id @default(uuid())
  userId         String
  walletId       String
  cardNumber     String     @unique
  cardHolder     String
  expiryDate     String     // e.g., "12/29"
  cvv            String
  status         CardStatus @default(ACTIVE)
  spendingLimit  Float      @default(1000.0)
  spentThisMonth Float      @default(0.0)
  cardType       String     @default("VISA Black")
  createdAt      DateTime   @default(now())

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet         Wallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Investment {
  id             String           @id @default(uuid())
  userId         String
  type           InvestmentType
  title          String
  targetAmount   Float?
  currentAmount  Float            @default(0.0)
  interestRate   Float            // Annual rate e.g., 5.5 for 5.5%
  durationMonths Int
  startDate      DateTime         @default(now())
  maturityDate   DateTime
  status         InvestmentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycRequest {
  id             String    @id @default(uuid())
  userId         String    @unique
  fullName       String
  dateOfBirth    String
  documentType   String    // e.g., "Passport", "Driver's License", "National ID"
  documentNumber String
  documentUrl    String
  status         KYCStatus @default(PENDING)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String    @id @default(uuid())
  userId         String
  title          String
  message        String
  isRead         Boolean   @default(false)
  type           String    @default("SYSTEM") // e.g., "TRANSFER", "SECURITY", "PROMOTION", "SYSTEM"
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Admin {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  role           String    @default("ADMIN") // "ADMIN" or "SUPER_ADMIN"
  createdAt      DateTime  @default(now())
}
